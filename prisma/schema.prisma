datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(uuid())
  telegramId  String   @unique
  username    String?
  firstName   String?
  photoUrl    String?
  role        String   @default("STAFF")
  createdAt   DateTime @default(now())
}

model Config {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Bon {
  id           String            @id @default(uuid())
  id_bon       String            @unique
  tanggal      DateTime          @default(now())
  pic          String
  keterangan   String
  nominal      Decimal           @db.Decimal(12, 2)
  status       String            @default("BELUM")
  transactions CashTransaction[]
}

model CashTransaction {
  id             String    @id @default(uuid())
  tanggal        DateTime  @default(now())
  tgl_nota       DateTime?
  akun           String?
  keterangan     String
  pic            String?
  jenis          String    
  jumlah         Decimal   @db.Decimal(12, 2)
  tgl_penagihan  DateTime?
  lampiran       String?
  bonId          String?
  bon            Bon?      @relation(fields: [bonId], references: [id], onDelete: Cascade)
}
